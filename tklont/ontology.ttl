                                                  rdfs:subPropertyOf <https://w3id.org/tklont/enforcesRuleOf> ;
                                                  rdfs:domain <https://w3id.org/tklont/Indigenous_Local_Community> ;
                                                  rdfs:range <https://w3id.org/tklont/Treatment_Rule> .


###  https://w3id.org/tklont/enforcesUseRuleOf
<https://w3id.org/tklont/enforcesUseRuleOf> rdf:type owl:ObjectProperty ;
                                            rdfs:subPropertyOf <https://w3id.org/tklont/enforcesRuleOf> ;
