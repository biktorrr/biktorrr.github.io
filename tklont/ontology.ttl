                                                  rdfs:subPropertyOf <https://w3id.org/tklont/emphasizesAssociationOf> ;
                                                  rdfs:domain <https://w3id.org/tklont/Creator_Connection_Label> ;
                                                  rdfs:range <https://w3id.org/tklont/Creator_Information> .


