@prefix : <http://tkl-ontology#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@base <http://tkl-ontology#> .

<http://tkl-ontology> rdf:type owl:Ontology .

#################################################################
#    Annotation properties
#################################################################

###  http://swrl.stanford.edu/ontologies/3.3/swrla.owl#isRuleEnabled
<http://swrl.stanford.edu/ontologies/3.3/swrla.owl#isRuleEnabled> rdf:type owl:AnnotationProperty .


#################################################################
#    Object Properties
#################################################################

###  http://www.semanticweb.org/christiannababan/ontologies/2025/3/untitled-ontology-208/isKnowledgeContainedInMaterial
<http://www.semanticweb.org/christiannababan/ontologies/2025/3/untitled-ontology-208/isKnowledgeContainedInMaterial> rdf:type owl:ObjectProperty ;
                                                                                                                     rdfs:subPropertyOf owl:topObjectProperty ;
                                                                                                                     rdfs:domain <https://w3id.org/tklont/Traditional_Knowledge> ;
                                                                                                                     rdfs:range <https://w3id.org/tklont/Material> .


###  https://w3id.org/tklont/acknowledgedOn
<https://w3id.org/tklont/acknowledgedOn> rdf:type owl:ObjectProperty ;
                                         rdfs:subPropertyOf owl:topObjectProperty ;
                                         owl:inverseOf <https://w3id.org/tklont/hasCondition> ;
                                         rdfs:domain <https://w3id.org/tklont/Condition> ;
                                         rdfs:range <https://w3id.org/tklont/Material> ;
                                         rdfs:comment "Conditions of a material. For query purpose" .


###  https://w3id.org/tklont/assertsSovereigntyOver
<https://w3id.org/tklont/assertsSovereigntyOver> rdf:type owl:ObjectProperty ;
                                                 rdfs:subPropertyOf owl:topObjectProperty ;
                                                 rdfs:domain <https://w3id.org/tklont/Indigenous_Local_Community> ;
                                                 rdfs:range <https://w3id.org/tklont/Material> ;
                                                 rdfs:comment "signifies that an ILC has asserted its sovereignty over a material by assigning label to a material" .


###  https://w3id.org/tklont/assigned
<https://w3id.org/tklont/assigned> rdf:type owl:ObjectProperty ;
                                   rdfs:subPropertyOf owl:topObjectProperty ;
                                   owl:inverseOf <https://w3id.org/tklont/assignedTo> ;
                                   rdfs:domain <https://w3id.org/tklont/Material> ;
                                   rdfs:range <https://w3id.org/tklont/TKL_Label> ;
                                   rdfs:comment "Labels that are assigned on a material" .


###  https://w3id.org/tklont/assignedTo
<https://w3id.org/tklont/assignedTo> rdf:type owl:ObjectProperty ;
                                     rdfs:subPropertyOf owl:topObjectProperty ;
                                     rdfs:domain <https://w3id.org/tklont/TKL_Label> ;
                                     rdfs:range <https://w3id.org/tklont/Material> ;
                                     rdfs:comment "material that each labels are assigned to." .


###  https://w3id.org/tklont/assigns
<https://w3id.org/tklont/assigns> rdf:type owl:ObjectProperty ;
                                  rdfs:subPropertyOf owl:topObjectProperty ;
                                  rdfs:domain <https://w3id.org/tklont/Indigenous_Local_Community> ;
                                  rdfs:range <https://w3id.org/tklont/TKL_Label> ;
                                  rdfs:comment "Action where an ILC assigns a label." .


###  https://w3id.org/tklont/consistsOfArrangement
<https://w3id.org/tklont/consistsOfArrangement> rdf:type owl:ObjectProperty ;
                                                rdfs:subPropertyOf owl:topObjectProperty ;
                                                rdfs:domain <https://w3id.org/tklont/Protocol> ;
                                                rdfs:range <https://w3id.org/tklont/Geographical_Condition> ,
                                                           <https://w3id.org/tklont/Periodical_Condition> ,
                                                           <https://w3id.org/tklont/Rule> ,
                                                           <https://w3id.org/tklont/Specific_Use_Condition> .


###  https://w3id.org/tklont/containsCreatorInformation
<https://w3id.org/tklont/containsCreatorInformation> rdf:type owl:ObjectProperty ;
                                                     rdfs:subPropertyOf <https://w3id.org/tklont/containsInformation> ;
                                                     rdfs:domain <https://w3id.org/tklont/Material> ;
                                                     rdfs:range <https://w3id.org/tklont/Creator_Information> .


###  https://w3id.org/tklont/containsCustodianshipInformation
<https://w3id.org/tklont/containsCustodianshipInformation> rdf:type owl:ObjectProperty ;
                                                           rdfs:subPropertyOf <https://w3id.org/tklont/containsInformation> ;
                                                           rdfs:domain <https://w3id.org/tklont/Material> ;
                                                           rdfs:range <https://w3id.org/tklont/Custodianship_Information> .


###  https://w3id.org/tklont/containsDSIInformation
<https://w3id.org/tklont/containsDSIInformation> rdf:type owl:ObjectProperty ;
                                                 rdfs:subPropertyOf <https://w3id.org/tklont/containsInformation> ;
                                                 rdfs:domain <https://w3id.org/tklont/Material> ;
                                                 rdfs:range <https://w3id.org/tklont/Data_Sequencing_Information> .


###  https://w3id.org/tklont/containsInformation
<https://w3id.org/tklont/containsInformation> rdf:type owl:ObjectProperty ;
                                              rdfs:subPropertyOf owl:topObjectProperty ;
                                              rdfs:comment "Information about an object. In case there the information incomplete or wrong, it has to be fixed in the future." .


###  https://w3id.org/tklont/containsOwnershipInformation
<https://w3id.org/tklont/containsOwnershipInformation> rdf:type owl:ObjectProperty ;
                                                       rdfs:subPropertyOf <https://w3id.org/tklont/containsInformation> ;
                                                       rdfs:domain <https://w3id.org/tklont/Material> ;
                                                       rdfs:range <https://w3id.org/tklont/Ownership_Information> .


###  https://w3id.org/tklont/containsProtocol
<https://w3id.org/tklont/containsProtocol> rdf:type owl:ObjectProperty ;
                                           rdfs:subPropertyOf owl:topObjectProperty ;
                                           rdfs:domain <https://w3id.org/tklont/Material> ;
                                           rdfs:range <https://w3id.org/tklont/Protocol> .


###  https://w3id.org/tklont/containsTraditionalKnowledgeInformation
<https://w3id.org/tklont/containsTraditionalKnowledgeInformation> rdf:type owl:ObjectProperty ;
                                                                  rdfs:subPropertyOf <https://w3id.org/tklont/containsInformation> ;
                                                                  owl:inverseOf <http://www.semanticweb.org/christiannababan/ontologies/2025/3/untitled-ontology-208/isKnowledgeContainedInMaterial> ;
                                                                  rdfs:domain <https://w3id.org/tklont/Material> ;
                                                                  rdfs:range <https://w3id.org/tklont/Traditional_Knowledge> .


###  https://w3id.org/tklont/emphasizesAssociationOf
<https://w3id.org/tklont/emphasizesAssociationOf> rdf:type owl:ObjectProperty ;
                                                  rdfs:subPropertyOf owl:topObjectProperty ;
                                                  rdfs:comment "Label that expresses how an ILC wants to emphasize a specific information." .


###  https://w3id.org/tklont/emphasizesAssociationOn
<https://w3id.org/tklont/emphasizesAssociationOn> rdf:type owl:ObjectProperty ;
                                                  rdfs:subPropertyOf owl:topObjectProperty ;
                                                  rdfs:comment "Label that expresses how an ILC wants to emphasize a specific information to display on a material." .


###  https://w3id.org/tklont/enforcesAccessRuleOf
<https://w3id.org/tklont/enforcesAccessRuleOf> rdf:type owl:ObjectProperty ;
                                               rdfs:subPropertyOf <https://w3id.org/tklont/enforcesRuleOf> ;
                                               rdfs:domain <https://w3id.org/tklont/Indigenous_Local_Community> ;
                                               rdfs:range <https://w3id.org/tklont/Access_Rule> .


###  https://w3id.org/tklont/enforcesAuthorizedRuleOf
<https://w3id.org/tklont/enforcesAuthorizedRuleOf> rdf:type owl:ObjectProperty ;
                                                   rdfs:subPropertyOf <https://w3id.org/tklont/enforcesRuleOf> ;
                                                   rdfs:domain <https://w3id.org/tklont/Indigenous_Local_Community> .


###  https://w3id.org/tklont/enforcesCirculationRuleOf
<https://w3id.org/tklont/enforcesCirculationRuleOf> rdf:type owl:ObjectProperty ;
                                                    rdfs:subPropertyOf <https://w3id.org/tklont/enforcesRuleOf> ;
                                                    rdfs:domain <https://w3id.org/tklont/Indigenous_Local_Community> ;
                                                    rdfs:range <https://w3id.org/tklont/Circulation_Rule> .


###  https://w3id.org/tklont/enforcesClanOnlyRuleOf
<https://w3id.org/tklont/enforcesClanOnlyRuleOf> rdf:type owl:ObjectProperty ;
                                                 rdfs:subPropertyOf <https://w3id.org/tklont/enforcesRuleOf> ;
                                                 rdfs:domain <https://w3id.org/tklont/Indigenous_Local_Community> ;
                                                 rdfs:range <https://w3id.org/tklont/Clan_Only_Rule> .


###  https://w3id.org/tklont/enforcesFamilyOnlyRuleOf
<https://w3id.org/tklont/enforcesFamilyOnlyRuleOf> rdf:type owl:ObjectProperty ;
                                                   rdfs:subPropertyOf <https://w3id.org/tklont/enforcesRuleOf> ;
                                                   rdfs:domain <https://w3id.org/tklont/Indigenous_Local_Community> ;
                                                   rdfs:range <https://w3id.org/tklont/Family_Only_Rule> .


###  https://w3id.org/tklont/enforcesMenOnlyRuleOf
<https://w3id.org/tklont/enforcesMenOnlyRuleOf> rdf:type owl:ObjectProperty ;
                                                rdfs:subPropertyOf <https://w3id.org/tklont/enforcesRuleOf> ;
                                                rdfs:domain <https://w3id.org/tklont/Indigenous_Local_Community> .


###  https://w3id.org/tklont/enforcesRuleOf
<https://w3id.org/tklont/enforcesRuleOf> rdf:type owl:ObjectProperty ;
                                         rdfs:subPropertyOf owl:topObjectProperty ;
                                         rdfs:comment "A specific rule that an ILC normally enforces." .


###  https://w3id.org/tklont/enforcesSafeStorageRuleOf
<https://w3id.org/tklont/enforcesSafeStorageRuleOf> rdf:type owl:ObjectProperty ;
                                                    rdfs:subPropertyOf <https://w3id.org/tklont/enforcesRuleOf> ;
