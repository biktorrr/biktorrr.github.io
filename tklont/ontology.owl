    <rdf:Description rdf:about="http://www.semanticweb.org/christiannababan/ontologies/2025/3/untitled-ontology-208/condition">
        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#Variable"/>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/christiannababan/ontologies/2025/3/untitled-ontology-208/protocol">
        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#Variable"/>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/christiannababan/ontologies/2025/3/untitled-ontology-208/material">
        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#Variable"/>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/christiannababan/ontologies/2025/3/untitled-ontology-208/ilc">
        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#Variable"/>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/christiannababan/ontologies/2025/3/untitled-ontology-208/custodian">
        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#Variable"/>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/christiannababan/ontologies/2025/3/untitled-ontology-208/purpose">
        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#Variable"/>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/christiannababan/ontologies/2025/3/untitled-ontology-208/label">
        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#Variable"/>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/christiannababan/ontologies/2025/3/untitled-ontology-208/rule">
        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#Variable"/>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/christiannababan/ontologies/2025/3/untitled-ontology-208/information">
        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#Variable"/>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/christiannababan/ontologies/2025/3/untitled-ontology-208/creator">
        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#Variable"/>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/christiannababan/ontologies/2025/3/untitled-ontology-208/group">
        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#Variable"/>
    </rdf:Description>
    <rdf:Description>
        <swrla:isRuleEnabled rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</swrla:isRuleEnabled>
        <rdfs:comment></rdfs:comment>
        <rdfs:label>Purpose-Activity-Information_Completion</rdfs:label>
        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#Imp"/>
        <swrl:body>
            <rdf:Description>
                <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#AtomList"/>
                <rdf:first>
                    <rdf:Description>
                        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#ClassAtom"/>
                        <swrl:classPredicate rdf:resource="https://w3id.org/tklont/Custodian_Organization"/>
                        <swrl:argument1 rdf:resource="http://www.semanticweb.org/christiannababan/ontologies/2025/3/untitled-ontology-208/custodian"/>
                    </rdf:Description>
                </rdf:first>
                <rdf:rest>
                    <rdf:Description>
                        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#AtomList"/>
                        <rdf:first>
                            <rdf:Description>
                                <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#IndividualPropertyAtom"/>
                                <swrl:propertyPredicate rdf:resource="https://w3id.org/tklont/assigns"/>
                                <swrl:argument1 rdf:resource="http://www.semanticweb.org/christiannababan/ontologies/2025/3/untitled-ontology-208/ilc"/>
                                <swrl:argument2 rdf:resource="http://www.semanticweb.org/christiannababan/ontologies/2025/3/untitled-ontology-208/label"/>
                            </rdf:Description>
                        </rdf:first>
                        <rdf:rest>
                            <rdf:Description>
                                <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#AtomList"/>
                                <rdf:first>
                                    <rdf:Description>
                                        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#ClassAtom"/>
                                        <swrl:classPredicate rdf:resource="https://w3id.org/tklont/Indigenous_Local_Community"/>
                                        <swrl:argument1 rdf:resource="http://www.semanticweb.org/christiannababan/ontologies/2025/3/untitled-ontology-208/ilc"/>
                                    </rdf:Description>
                                </rdf:first>
                                <rdf:rest>
                                    <rdf:Description>
                                        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#AtomList"/>
                                        <rdf:first>
                                            <rdf:Description>
                                                <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#IndividualPropertyAtom"/>
                                                <swrl:propertyPredicate rdf:resource="https://w3id.org/tklont/hosts"/>
                                                <swrl:argument1 rdf:resource="http://www.semanticweb.org/christiannababan/ontologies/2025/3/untitled-ontology-208/custodian"/>
                                                <swrl:argument2 rdf:resource="http://www.semanticweb.org/christiannababan/ontologies/2025/3/untitled-ontology-208/material"/>
                                            </rdf:Description>
                                        </rdf:first>
                                        <rdf:rest>
                                            <rdf:Description>
                                                <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#AtomList"/>
                                                <rdf:first>
                                                    <rdf:Description>
                                                        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#ClassAtom"/>
                                                        <swrl:classPredicate rdf:resource="https://w3id.org/tklont/TKL_Label"/>
                                                        <swrl:argument1 rdf:resource="http://www.semanticweb.org/christiannababan/ontologies/2025/3/untitled-ontology-208/label"/>
                                                    </rdf:Description>
                                                </rdf:first>
                                                <rdf:rest>
                                                    <rdf:Description>
                                                        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#AtomList"/>
                                                        <rdf:first>
                                                            <rdf:Description>
                                                                <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#IndividualPropertyAtom"/>
                                                                <swrl:propertyPredicate rdf:resource="https://w3id.org/tklont/hasInformationCompletionActivityWishOf"/>
                                                                <swrl:argument1 rdf:resource="http://www.semanticweb.org/christiannababan/ontologies/2025/3/untitled-ontology-208/ilc"/>
                                                                <swrl:argument2 rdf:resource="http://www.semanticweb.org/christiannababan/ontologies/2025/3/untitled-ontology-208/purpose"/>
                                                            </rdf:Description>
                                                        </rdf:first>
                                                        <rdf:rest>
                                                            <rdf:Description>
                                                                <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#AtomList"/>
                                                                <rdf:first>
                                                                    <rdf:Description>
                                                                        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#IndividualPropertyAtom"/>
                                                                        <swrl:propertyPredicate rdf:resource="https://w3id.org/tklont/hasPrimaryOwnershipOn"/>
                                                                        <swrl:argument1 rdf:resource="http://www.semanticweb.org/christiannababan/ontologies/2025/3/untitled-ontology-208/ilc"/>
                                                                        <swrl:argument2 rdf:resource="http://www.semanticweb.org/christiannababan/ontologies/2025/3/untitled-ontology-208/material"/>
                                                                    </rdf:Description>
                                                                </rdf:first>
                                                                <rdf:rest>
                                                                    <rdf:Description>
                                                                        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#AtomList"/>
                                                                        <rdf:first>
                                                                            <rdf:Description>
                                                                                <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#IndividualPropertyAtom"/>
                                                                                <swrl:propertyPredicate rdf:resource="https://w3id.org/tklont/hasNeed"/>
                                                                                <swrl:argument1 rdf:resource="http://www.semanticweb.org/christiannababan/ontologies/2025/3/untitled-ontology-208/material"/>
