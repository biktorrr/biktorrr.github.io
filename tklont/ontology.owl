<?xml version="1.0"?>
<rdf:RDF xmlns="http://tkl-ontology#"
     xml:base="http://tkl-ontology"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:swrl="http://www.w3.org/2003/11/swrl#"
     xmlns:swrla="http://swrl.stanford.edu/ontologies/3.3/swrla.owl#"
     xmlns:swrlb="http://www.w3.org/2003/11/swrlb#"
     xmlns:tklont="https://w3id.org/tklont/">
    <owl:Ontology rdf:about="http://tkl-ontology"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Annotation properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://swrl.stanford.edu/ontologies/3.3/swrla.owl#isRuleEnabled -->


    <owl:AnnotationProperty rdf:about="http://swrl.stanford.edu/ontologies/3.3/swrla.owl#isRuleEnabled"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://www.semanticweb.org/christiannababan/ontologies/2025/3/untitled-ontology-208/isKnowledgeContainedInMaterial -->


    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/christiannababan/ontologies/2025/3/untitled-ontology-208/isKnowledgeContainedInMaterial">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <rdfs:domain rdf:resource="https://w3id.org/tklont/Traditional_Knowledge"/>
        <rdfs:range rdf:resource="https://w3id.org/tklont/Material"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/tklont/acknowledgedOn -->


    <owl:ObjectProperty rdf:about="https://w3id.org/tklont/acknowledgedOn">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <owl:inverseOf rdf:resource="https://w3id.org/tklont/hasCondition"/>
        <rdfs:domain rdf:resource="https://w3id.org/tklont/Condition"/>
        <rdfs:range rdf:resource="https://w3id.org/tklont/Material"/>
        <rdfs:comment>Conditions of a material. For query purpose</rdfs:comment>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/tklont/assertsSovereigntyOver -->


    <owl:ObjectProperty rdf:about="https://w3id.org/tklont/assertsSovereigntyOver">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <rdfs:domain rdf:resource="https://w3id.org/tklont/Indigenous_Local_Community"/>
        <rdfs:range rdf:resource="https://w3id.org/tklont/Material"/>
        <rdfs:comment>signifies that an ILC has asserted its sovereignty over a material by assigning label to a material</rdfs:comment>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/tklont/assigned -->


    <owl:ObjectProperty rdf:about="https://w3id.org/tklont/assigned">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <owl:inverseOf rdf:resource="https://w3id.org/tklont/assignedTo"/>
        <rdfs:domain rdf:resource="https://w3id.org/tklont/Material"/>
        <rdfs:range rdf:resource="https://w3id.org/tklont/TKL_Label"/>
        <rdfs:comment>Labels that are assigned on a material</rdfs:comment>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/tklont/assignedTo -->


    <owl:ObjectProperty rdf:about="https://w3id.org/tklont/assignedTo">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <rdfs:domain rdf:resource="https://w3id.org/tklont/TKL_Label"/>
        <rdfs:range rdf:resource="https://w3id.org/tklont/Material"/>
        <rdfs:comment>material that each labels are assigned to.</rdfs:comment>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/tklont/assigns -->


    <owl:ObjectProperty rdf:about="https://w3id.org/tklont/assigns">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <rdfs:domain rdf:resource="https://w3id.org/tklont/Indigenous_Local_Community"/>
        <rdfs:range rdf:resource="https://w3id.org/tklont/TKL_Label"/>
        <rdfs:comment>Action where an ILC assigns a label.</rdfs:comment>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/tklont/consistsOfArrangement -->


    <owl:ObjectProperty rdf:about="https://w3id.org/tklont/consistsOfArrangement">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <rdfs:domain rdf:resource="https://w3id.org/tklont/Protocol"/>
        <rdfs:range rdf:resource="https://w3id.org/tklont/Geographical_Condition"/>
        <rdfs:range rdf:resource="https://w3id.org/tklont/Periodical_Condition"/>
        <rdfs:range rdf:resource="https://w3id.org/tklont/Rule"/>
        <rdfs:range rdf:resource="https://w3id.org/tklont/Specific_Use_Condition"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/tklont/containsCreatorInformation -->


    <owl:ObjectProperty rdf:about="https://w3id.org/tklont/containsCreatorInformation">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/tklont/containsInformation"/>
        <rdfs:domain rdf:resource="https://w3id.org/tklont/Material"/>
        <rdfs:range rdf:resource="https://w3id.org/tklont/Creator_Information"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/tklont/containsCustodianshipInformation -->


    <owl:ObjectProperty rdf:about="https://w3id.org/tklont/containsCustodianshipInformation">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/tklont/containsInformation"/>
        <rdfs:domain rdf:resource="https://w3id.org/tklont/Material"/>
        <rdfs:range rdf:resource="https://w3id.org/tklont/Custodianship_Information"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/tklont/containsDSIInformation -->


    <owl:ObjectProperty rdf:about="https://w3id.org/tklont/containsDSIInformation">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/tklont/containsInformation"/>
        <rdfs:domain rdf:resource="https://w3id.org/tklont/Material"/>
        <rdfs:range rdf:resource="https://w3id.org/tklont/Data_Sequencing_Information"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/tklont/containsInformation -->


    <owl:ObjectProperty rdf:about="https://w3id.org/tklont/containsInformation">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <rdfs:comment>Information about an object. In case there the information incomplete or wrong, it has to be fixed in the future.</rdfs:comment>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/tklont/containsOwnershipInformation -->


    <owl:ObjectProperty rdf:about="https://w3id.org/tklont/containsOwnershipInformation">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/tklont/containsInformation"/>
        <rdfs:domain rdf:resource="https://w3id.org/tklont/Material"/>
        <rdfs:range rdf:resource="https://w3id.org/tklont/Ownership_Information"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/tklont/containsProtocol -->


    <owl:ObjectProperty rdf:about="https://w3id.org/tklont/containsProtocol">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <rdfs:domain rdf:resource="https://w3id.org/tklont/Material"/>
        <rdfs:range rdf:resource="https://w3id.org/tklont/Protocol"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/tklont/containsTraditionalKnowledgeInformation -->


    <owl:ObjectProperty rdf:about="https://w3id.org/tklont/containsTraditionalKnowledgeInformation">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/tklont/containsInformation"/>
        <owl:inverseOf rdf:resource="http://www.semanticweb.org/christiannababan/ontologies/2025/3/untitled-ontology-208/isKnowledgeContainedInMaterial"/>
        <rdfs:domain rdf:resource="https://w3id.org/tklont/Material"/>
        <rdfs:range rdf:resource="https://w3id.org/tklont/Traditional_Knowledge"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/tklont/emphasizesAssociationOf -->


    <owl:ObjectProperty rdf:about="https://w3id.org/tklont/emphasizesAssociationOf">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <rdfs:comment>Label that expresses how an ILC wants to emphasize a specific information.</rdfs:comment>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/tklont/emphasizesAssociationOn -->


    <owl:ObjectProperty rdf:about="https://w3id.org/tklont/emphasizesAssociationOn">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <rdfs:comment>Label that expresses how an ILC wants to emphasize a specific information to display on a material.</rdfs:comment>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/tklont/enforcesAccessRuleOf -->


    <owl:ObjectProperty rdf:about="https://w3id.org/tklont/enforcesAccessRuleOf">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/tklont/enforcesRuleOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/tklont/Indigenous_Local_Community"/>
        <rdfs:range rdf:resource="https://w3id.org/tklont/Access_Rule"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/tklont/enforcesAuthorizedRuleOf -->


    <owl:ObjectProperty rdf:about="https://w3id.org/tklont/enforcesAuthorizedRuleOf">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/tklont/enforcesRuleOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/tklont/Indigenous_Local_Community"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/tklont/enforcesCirculationRuleOf -->


    <owl:ObjectProperty rdf:about="https://w3id.org/tklont/enforcesCirculationRuleOf">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/tklont/enforcesRuleOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/tklont/Indigenous_Local_Community"/>
        <rdfs:range rdf:resource="https://w3id.org/tklont/Circulation_Rule"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/tklont/enforcesClanOnlyRuleOf -->


    <owl:ObjectProperty rdf:about="https://w3id.org/tklont/enforcesClanOnlyRuleOf">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/tklont/enforcesRuleOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/tklont/Indigenous_Local_Community"/>
        <rdfs:range rdf:resource="https://w3id.org/tklont/Clan_Only_Rule"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/tklont/enforcesFamilyOnlyRuleOf -->


    <owl:ObjectProperty rdf:about="https://w3id.org/tklont/enforcesFamilyOnlyRuleOf">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/tklont/enforcesRuleOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/tklont/Indigenous_Local_Community"/>
        <rdfs:range rdf:resource="https://w3id.org/tklont/Family_Only_Rule"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/tklont/enforcesMenOnlyRuleOf -->


    <owl:ObjectProperty rdf:about="https://w3id.org/tklont/enforcesMenOnlyRuleOf">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/tklont/enforcesRuleOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/tklont/Indigenous_Local_Community"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/tklont/enforcesRuleOf -->


    <owl:ObjectProperty rdf:about="https://w3id.org/tklont/enforcesRuleOf">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <rdfs:comment>A specific rule that an ILC normally enforces.</rdfs:comment>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/tklont/enforcesSafeStorageRuleOf -->


    <owl:ObjectProperty rdf:about="https://w3id.org/tklont/enforcesSafeStorageRuleOf">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/tklont/enforcesRuleOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/tklont/Indigenous_Local_Community"/>
        <rdfs:range rdf:resource="https://w3id.org/tklont/Safe_Storage_Rule"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/tklont/enforcesSharingRuleOf -->


    <owl:ObjectProperty rdf:about="https://w3id.org/tklont/enforcesSharingRuleOf">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/tklont/enforcesRuleOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/tklont/Indigenous_Local_Community"/>
        <rdfs:range rdf:resource="https://w3id.org/tklont/Sharing_Rule"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/tklont/enforcesTimePeriodRuleOf -->


    <owl:ObjectProperty rdf:about="https://w3id.org/tklont/enforcesTimePeriodRuleOf">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/tklont/enforcesRuleOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/tklont/Indigenous_Local_Community"/>
        <rdfs:range rdf:resource="https://w3id.org/tklont/Time_Period_Rule"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/tklont/enforcesTreatmentRuleOf -->


    <owl:ObjectProperty rdf:about="https://w3id.org/tklont/enforcesTreatmentRuleOf">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/tklont/enforcesRuleOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/tklont/Indigenous_Local_Community"/>
        <rdfs:range rdf:resource="https://w3id.org/tklont/Treatment_Rule"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/tklont/enforcesUseRuleOf -->


    <owl:ObjectProperty rdf:about="https://w3id.org/tklont/enforcesUseRuleOf">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/tklont/enforcesRuleOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/tklont/Indigenous_Local_Community"/>
        <rdfs:range rdf:resource="https://w3id.org/tklont/Use_Rule"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/tklont/enforcesWomenOnlyRuleOf -->


    <owl:ObjectProperty rdf:about="https://w3id.org/tklont/enforcesWomenOnlyRuleOf">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/tklont/enforcesRuleOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/tklont/Indigenous_Local_Community"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/tklont/explainsInformation -->


    <owl:ObjectProperty rdf:about="https://w3id.org/tklont/explainsInformation">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <owl:inverseOf rdf:resource="https://w3id.org/tklont/isExplainedByGroup"/>
        <rdfs:domain rdf:resource="https://w3id.org/tklont/Indigenous_Local_Community"/>
        <rdfs:range rdf:resource="https://w3id.org/tklont/Specific_Explanation"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/tklont/hasAssociationWith -->


    <owl:ObjectProperty rdf:about="https://w3id.org/tklont/hasAssociationWith">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <rdfs:domain rdf:resource="https://w3id.org/tklont/Material"/>
        <rdfs:range rdf:resource="https://w3id.org/tklont/Information"/>
        <rdfs:comment>Material has an association that it wants to display.</rdfs:comment>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/tklont/hasCirculationClarificationWishOf -->


    <owl:ObjectProperty rdf:about="https://w3id.org/tklont/hasCirculationClarificationWishOf">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/tklont/hasWishOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/tklont/Indigenous_Local_Community"/>
        <rdfs:range rdf:resource="https://w3id.org/tklont/Circulation_Clarification"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/tklont/hasColonialAssociationOf -->


    <owl:ObjectProperty rdf:about="https://w3id.org/tklont/hasColonialAssociationOf">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/tklont/emphasizesAssociationOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/tklont/Colonial_Connection_Label"/>
        <rdfs:range rdf:resource="https://w3id.org/tklont/Colonial_History"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/tklont/hasColonialAssociationOn -->


    <owl:ObjectProperty rdf:about="https://w3id.org/tklont/hasColonialAssociationOn">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/tklont/emphasizesAssociationOn"/>
        <rdfs:domain rdf:resource="https://w3id.org/tklont/Colonial_Connection_Label"/>
        <rdfs:range rdf:resource="https://w3id.org/tklont/Material"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/tklont/hasCommercializationActivityWishOf -->


    <owl:ObjectProperty rdf:about="https://w3id.org/tklont/hasCommercializationActivityWishOf">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/tklont/hasWishOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/tklont/Indigenous_Local_Community"/>
        <rdfs:range rdf:resource="https://w3id.org/tklont/Commercialization_Activity"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/tklont/hasCondition -->


    <owl:ObjectProperty rdf:about="https://w3id.org/tklont/hasCondition">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <rdfs:domain rdf:resource="https://w3id.org/tklont/Material"/>
        <rdfs:range rdf:resource="https://w3id.org/tklont/Condition"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/tklont/hasConditionClarificationWishOf -->


    <owl:ObjectProperty rdf:about="https://w3id.org/tklont/hasConditionClarificationWishOf">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/tklont/hasWishOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/tklont/Indigenous_Local_Community"/>
        <rdfs:range rdf:resource="https://w3id.org/tklont/Condition_Clarification"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/tklont/hasConditionExplanation -->


    <owl:ObjectProperty rdf:about="https://w3id.org/tklont/hasConditionExplanation">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/tklont/hasCorrectionActivityWishOf -->


    <owl:ObjectProperty rdf:about="https://w3id.org/tklont/hasCorrectionActivityWishOf">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/tklont/hasWishOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/tklont/Indigenous_Local_Community"/>
        <rdfs:range rdf:resource="https://w3id.org/tklont/Correction_Activity"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/tklont/hasCreatorAssociationOf -->


    <owl:ObjectProperty rdf:about="https://w3id.org/tklont/hasCreatorAssociationOf">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/tklont/emphasizesAssociationOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/tklont/Creator_Connection_Label"/>
        <rdfs:range rdf:resource="https://w3id.org/tklont/Creator_Information"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/tklont/hasCreatorAssociationOn -->


    <owl:ObjectProperty rdf:about="https://w3id.org/tklont/hasCreatorAssociationOn">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/tklont/emphasizesAssociationOn"/>
        <rdfs:domain rdf:resource="https://w3id.org/tklont/Creator_Connection_Label"/>
        <rdfs:range rdf:resource="https://w3id.org/tklont/Material"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/tklont/hasCreatorInformationOf -->


    <owl:ObjectProperty rdf:about="https://w3id.org/tklont/hasCreatorInformationOf">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/tklont/hasInformationOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/tklont/Collection_of_Person"/>
        <rdfs:range rdf:resource="https://w3id.org/tklont/Creator_Information"/>
        <rdfs:comment>Everyone, including the custodians and public individuals are allowed to fill in information about the creator of a material.</rdfs:comment>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/tklont/hasCulturalAppreciationEncouragementOf -->


    <owl:ObjectProperty rdf:about="https://w3id.org/tklont/hasCulturalAppreciationEncouragementOf">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/tklont/hasWishOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/tklont/Indigenous_Local_Community"/>
        <rdfs:range rdf:resource="https://w3id.org/tklont/Cultural_Appreciation_Encouragement"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/tklont/hasCustodianMember -->


    <owl:ObjectProperty rdf:about="https://w3id.org/tklont/hasCustodianMember">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/tklont/hasMember"/>
        <owl:inverseOf rdf:resource="https://w3id.org/tklont/memberCustodianOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/tklont/Custodian_Organization"/>
        <rdfs:range rdf:resource="https://w3id.org/tklont/Custodian"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/tklont/hasCustodianshipInformationOf -->


    <owl:ObjectProperty rdf:about="https://w3id.org/tklont/hasCustodianshipInformationOf">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/tklont/hasInformationOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/tklont/Collection_of_Person"/>
        <rdfs:range rdf:resource="https://w3id.org/tklont/Custodianship_Information"/>
        <rdfs:comment>Multiple entities can have the information on how the current custodian gain the material</rdfs:comment>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/tklont/hasDSIInformationOf -->


    <owl:ObjectProperty rdf:about="https://w3id.org/tklont/hasDSIInformationOf">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/tklont/hasInformationOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/tklont/Collection_of_Person"/>
        <rdfs:range rdf:resource="https://w3id.org/tklont/Data_Sequencing_Information"/>
        <rdfs:comment>Digital Sequence information can be understood by any parties.</rdfs:comment>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/tklont/hasDataConsentRequirement -->


    <owl:ObjectProperty rdf:about="https://w3id.org/tklont/hasDataConsentRequirement">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/tklont/hasRequirement"/>
        <rdfs:domain rdf:resource="https://w3id.org/tklont/Material"/>
        <rdfs:range rdf:resource="https://w3id.org/tklont/Indigenous_Local_Community"/>
    </owl:ObjectProperty>
    


